{
  "name": "ssh-agents-monitor",
  "version": "1.0.0",
  "description": "Real-time Claude Code Agent monitor dashboard",
  "main": "server/index.js",
  "scripts": {
    "start":       "node server/index.js",
    "build":       "cd client && pnpm install && pnpm run build",
    "dev:server":  "node server/index.js",
    "dev:client":  "cd client && pnpm run dev",
    "dev":         "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\""
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-notifier": "^10.0.1",
    "node-ssh": "^13.2.0",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
