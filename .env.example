# SSH connection settings - copy to .env and fill in
SSH_HOST=your-remote-server.com
SSH_PORT=22
SSH_USER=ubuntu
# Use either password or private key
SSH_PASSWORD=
SSH_KEY_PATH=~/.ssh/id_rsa

# Where agent logs are stored on remote server
REMOTE_LOG_DIR=/tmp/claude-agents

# How often to poll remote logs (milliseconds)
POLL_INTERVAL=3000

# Local server port
PORT=13845
